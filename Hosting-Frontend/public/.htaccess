<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /ReactDev/ # Set the correct base path

  RewriteRule ^index\.html$ - [L]

  # Skip rewrite if the request is for an existing file or directory
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L] # Do not rewrite anything further

  # If the request doesn't match an existing file/directory, rewrite to index.html
  # This rule is simpler and relies on the conditions above to protect assets.
  RewriteRule . /ReactDev/index.html [L]
</IfModule>

# Optional: Add specific MIME types if needed, though usually not required with correct rewrite rules
# <IfModule mod_mime.c>
#   AddType text/javascript .js
#   AddType text/css .css
# </IfModule>
