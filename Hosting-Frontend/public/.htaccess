<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /ReactDev/ # Set the correct base path

  RewriteRule ^index\.html$ - [L]

  # Add condition: Don't rewrite if the request URI starts with /ReactDev/assets/
  RewriteCond %{REQUEST_URI} !^/ReactDev/assets/
  # If the request is not for an existing file
  RewriteCond %{REQUEST_FILENAME} !-f
  # And the request is not for an existing directory
  RewriteCond %{REQUEST_FILENAME} !-d
  # Rewrite to the index.html in the /ReactDev directory (absolute path from web root)
  RewriteRule . /ReactDev/index.html [L]
</IfModule>
